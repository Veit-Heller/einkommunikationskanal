# Database (PostgreSQL - e.g. from Neon via Vercel)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# WhatsApp Cloud API (Meta Developer Dashboard)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# Microsoft Graph / Outlook (Azure Portal)
OUTLOOK_CLIENT_ID=""
OUTLOOK_CLIENT_SECRET=""
OUTLOOK_TENANT_ID="common"
OUTLOOK_REDIRECT_URI="https://YOUR-DOMAIN.vercel.app/api/integrations/outlook/callback"

# Next Auth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://YOUR-DOMAIN.vercel.app"
