# Database (PostgreSQL - e.g. from Neon via Vercel)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Login password for the CRM (only you know this)
ADMIN_PASSWORD="dein-sicheres-passwort"

# WhatsApp Cloud API (Meta Developer Dashboard)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# Gmail (Google Cloud Console → APIs & Dienste → OAuth 2.0)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="https://YOUR-DOMAIN.vercel.app/api/integrations/gmail/callback"

# Next Auth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://YOUR-DOMAIN.vercel.app"
